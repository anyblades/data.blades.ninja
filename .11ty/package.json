{
  "private": true,
  "name": "subtle.blades.ninja",
  "type": "module",
  "workspaces": [
    "do"
  ],
  "scripts": {
    "start": "npm run build -- --serve",
    "stage": "rm -r ./_site || true && npm run build && serve ./_site/",
    "build": "eleventy --input=../ --config=./node_modules/@anyblades/eleventy-blades-base/eleventy.config.js"
  },
  "devDependencies": {
    "prettier-plugin-jinja-template": "^2.1.0",
    "serve": "^14.2.5"
  },
  "dependencies": {
    "@anyblades/eleventy-blades": "^0.29.0-beta.3",
    "@anyblades/eleventy-blades-base": "^0.4.1"
  },
  "=== SITE GLOBALS": "===",
  "site": {
    "title": "Subtle",
    "styles": [
      "/blades.css",
      "https://cdn.jsdelivr.net/npm/prismjs@1/themes/prism-tomorrow.min.css"
    ],
    "scripts": [
      "https://cdn.jsdelivr.net/npm/prismjs@1/components/prism-core.min.js",
      "https://cdn.jsdelivr.net/npm/prismjs@1/plugins/autoloader/prism-autoloader.min.js"
    ]
  },
